{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korego.dev/schemas/chown.schema.json",
  "title": "KoreGo chown --json output",
  "description": "Validates the complete JSON output of korego chown --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "chown" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"type": "object", "required": ["changed"], "properties": {"changed": {"type": "array", "items": {"type": "object", "required": ["path"], "properties": {"path": {"type": "string"}}}}}},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
