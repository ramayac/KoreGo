{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korego.dev/schemas/ps.schema.json",
  "title": "KoreGo ps --json output",
  "description": "Validates the complete JSON output of korego ps --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "ps" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"type": "array", "items": {"type": "object", "required": ["pid", "ppid", "user", "cmd", "cpu", "mem"], "properties": {"pid": {"type": "integer"}, "ppid": {"type": "integer"}, "user": {"type": "string"}, "cmd": {"type": "string"}, "cpu": {"type": "string"}, "mem": {"type": "string"}}}},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
