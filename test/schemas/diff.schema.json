{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korego.dev/schemas/diff.schema.json",
  "title": "KoreGo diff --json output",
  "description": "Validates the complete JSON output of korego diff --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "diff" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"type": "object", "required": ["files", "differ", "hunks"], "properties": {"files": {"type": "array", "items": {"type": "string"}}, "differ": {"type": "boolean"}, "hunks": {"type": "array", "items": {"type": "object", "required": ["oldStart", "oldLines", "newStart", "newLines", "lines"], "properties": {"oldStart": {"type": "integer"}, "oldLines": {"type": "integer"}, "newStart": {"type": "integer"}, "newLines": {"type": "integer"}, "lines": {"type": "array", "items": {"type": "string"}}}}}}},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
