{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korego.dev/schemas/sha256sum.schema.json",
  "title": "KoreGo sha256sum --json output",
  "description": "Validates the complete JSON output of korego sha256sum --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "sha256sum" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"oneOf": [{"type": "array", "items": {"type": "object", "required": ["file", "hash", "algorithm"], "properties": {"file": {"type": "string"}, "hash": {"type": "string"}, "algorithm": {"type": "string", "const": "sha256"}}}}, {"type": "array", "items": {"type": "object", "required": ["file", "status"], "properties": {"file": {"type": "string"}, "status": {"type": "string", "enum": ["OK", "FAILED"]}}}}]},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
