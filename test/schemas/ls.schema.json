    "data": {"oneOf": [{"type": "object", "required": ["path", "files", "total"], "properties": {"path": {"type": "string"}, "files": {"type": "array", "items": {"type": "object", "required": ["name", "path", "size", "mode", "modTime", "isDir", "owner", "group", "inode", "links", "blocks"], "properties": {"name": {"type": "string"}, "path": {"type": "string"}, "size": {"type": "integer"}, "mode": {"type": "string"}, "modTime": {"type": "string"}, "isDir": {"type": "boolean"}, "owner": {"type": "string"}, "group": {"type": "string"}, "inode": {"type": "integer"}, "links": {"type": "integer"}, "target": {"type": "string"}, "blocks": {"type": "integer"}}}}, "total": {"type": "integer"}}}, {"type": "array", "items": {"type": "object", "required": ["path", "files", "total"], "properties": {"path": {"type": "string"}, "files": {"type": "array", "items": {"type": "object", "required": ["name", "path", "size", "mode", "modTime", "isDir", "owner", "group", "inode", "links", "blocks"], "properties": {"name": {"type": "string"}, "path": {"type": "string"}, "size": {"type": "integer"}, "mode": {"type": "string"}, "modTime": {"type": "string"}, "isDir": {"type": "boolean"}, "owner": {"type": "string"}, "group": {"type": "string"}, "inode": {"type": "integer"}, "links": {"type": "integer"}, "target": {"type": "string"}, "blocks": {"type": "integer"}}}}, "total": {"type": "integer"}}}}]},
